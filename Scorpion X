    TitleLabel.Size = UDim2.new(1, -100, 1, 0); TitleLabel.Position = UDim2.new(0, 15, 0, 0); TitleLabel.BackgroundTransparency = 1; TitleLabel.TextColor3 = ColoreTestoPrincipale; TitleLabel.Font = Enum.Font.GothamMedium; TitleLabel.TextSize = 13; TitleLabel.TextXAlignment = Enum.TextXAlignment.Left; TitleLabel.Text = titoloHub; TitleLabel.Parent = TopBar

    RendiTrascinabile(MainFrame, TopBar)

    local CloseBtn = Instance.new("TextButton")
