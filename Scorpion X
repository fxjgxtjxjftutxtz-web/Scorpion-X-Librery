                local srv = ReplicatedStorage.Aero.AeroRemoteServices:FindFirstChild("GameService")
                if uiCtrl and srv then
                    local data = require(uiCtrl)
                    local list = {}
                    local petsShared = data.Shared and data.Shared.Pets

                    for uid, info in pairs(data.Data) do
                        local totalMultiplier = 0
                        if petsShared and petsShared.GetXpBoost then
                            local xpB = petsShared:GetXpBoost(info.ptype, info.level, info.evo) or 1
                            local spB = petsShared.GetSpeedBoost and petsShared:GetSpeedBoost(info.ptype, info.level, info.evo) or 1
                            local glB = petsShared.GetGoldBoost and petsShared:GetGoldBoost(info.ptype, info.level, info.evo) or 1
                            totalMultiplier = xpB + spB + glB
                        else
                            totalMultiplier = (info.evo or 0) * 10 + (info.level or 1)
                        end

                        table.insert(list, {
                            uid = uid, 
                            power = totalMultiplier, 
                            eq = info.equipped or false
                        })
                    end

                    table.sort(list, function(a,b) return a.power > b.power end)

                    local slots = 2
                    if data.MaxPets and data.FourMaxPets then
                        if data.MaxPets.Value == true then slots = slots + 2 end
                        if data.FourMaxPets.Value == true then slots = slots + 4 end
                    end
                    if data.PetEquipSlotsRef then slots = data.PetEquipSlotsRef.Value end

                    for i, pet in ipairs(list) do
                        if i <= slots then
                            if not pet.eq then 
                                srv.RequestEquipPet:InvokeServer(pet.uid, true) 
                                task.wait(0.08) 
                            end
                        else
                            if pet.eq then 
                                srv.RequestEquipPet:InvokeServer(pet.uid, false) 
                                task.wait(0.08) 
                            end
                        end
                    end
                end
            end)
            task.wait(3.0)
        else task.wait(1.0) end
    end
end)

