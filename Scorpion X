    function InterfacciaEngine:AggiungiKeybind(parentTab, titleText, defaultKey, callback)
        local c = Instance.new("Frame", parentTab)
        c.Size, c.BackgroundColor3 = UDim2.new(0.95, 0, 0, 40), Color3.fromRGB(22, 22, 22)
        addDecor(c, 6)

        local tl = Instance.new("TextLabel", c)
        tl.Size, tl.Position, tl.BackgroundTransparency, tl.TextColor3, tl.Font, tl.TextSize, tl.TextXAlignment, tl.Text = UDim2.new(0.6, 0, 1, 0), UDim2.new(0, 10, 0, 0), 1, Color3.fromRGB(255, 255, 255), Enum.Font.SourceSansSemibold, 13, Enum.TextXAlignment.Left, titleText

        local bBtn = Instance.new("TextButton", c)
        bBtn.Size, bBtn.Position, bBtn.BackgroundColor3, bBtn.TextColor3, bBtn.Font, bBtn.TextSize, bBtn.Text = UDim2.new(0, 80, 0, 24), UDim2.new(1, -90, 0.5, -12), Color3.fromRGB(30, 30, 30), Color3.fromRGB(150, 255, 0), Enum.Font.SourceSansBold, 12, defaultKey.Name
        addDecor(bBtn, 4)

        local curKey, listening = defaultKey, false
        bBtn.MouseButton1Click:Connect(function() listening = true bBtn.Text, bBtn.TextColor3 = "...", Color3.fromRGB(255, 255, 0) end)

        UIS.InputBegan:Connect(function(input, processed)
            if processed then return end
            if listening and input.UserInputType == Enum.UserInputType.Keyboard then
                listening = false curKey = input.KeyCode
                bBtn.Text, bBtn.TextColor3 = curKey.Name, Color3.fromRGB(150, 255, 0)
                callback(curKey, false)
            elseif not listening and input.KeyCode == curKey then
                callback(curKey, true)
            end
        end)
        return c
    end

    task.spawn(function()
        task.wait(0.2)
        if self.primaTab and self.tabs[self.primaTab] then
            self.tabs[self.primaTab].Visible = true
            if self.tabButtons[self.primaTab] then
                self.tabButtons[self.primaTab].BackgroundColor3, self.tabButtons[self.primaTab].TextColor3 = Color3.fromRGB(150, 255, 0), Color3.fromRGB(0, 0, 0)
            end
        end
    end)

    return InterfacciaEngine
end

return Library
