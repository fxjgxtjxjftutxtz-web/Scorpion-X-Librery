        local dropCorner = Instance.new("UICorner"); dropCorner.CornerRadius = UDim.new(0, 6); dropCorner.Parent = dropBtn
        local dropStroke = Instance.new("UIStroke"); dropStroke.Thickness = 1; dropStroke.Color = Color3.fromRGB(24, 24, 27); dropStroke.Parent = dropBtn
        local dropListFrame = Instance.new("ScrollingFrame"); dropListFrame.Name = "DropList"; dropListFrame.Size = UDim2.new(1, 0, 0, 0); dropListFrame.Position = UDim2.new(0, 0, 0, 38); dropListFrame.BackgroundColor3 = Color3.fromRGB(12, 12, 14); dropListFrame.Visible = false; dropListFrame.ScrollBarThickness = 2; dropListFrame.ScrollBarImageColor3 = VerdeTema; dropListFrame.CanvasSize = UDim2.new(0, 0, 0, #options * 30); dropListFrame.Parent = dropContainer
        local dCorner = Instance.new("UICorner"); dCorner.CornerRadius = UDim.new(0, 6); dCorner.Parent = dropListFrame
        local dStroke = Instance.new("UIStroke"); dStroke.Thickness = 1; dStroke.Color = Color3.fromRGB(35, 35, 40); dStroke.Parent = dropListFrame
        local dropLayout = Instance.new("UIListLayout"); dropLayout.SortOrder = Enum.SortOrder.LayoutOrder; dropLayout.Parent = dropListFrame

        for i, val in ipairs(options) do
            local opt = Instance.new("TextButton"); opt.Size = UDim2.new(1, 0, 0, 30); opt.BackgroundColor3 = Color3.fromRGB(14, 14, 16); opt.TextColor3 = Color3.fromRGB(200, 200, 205); opt.Font = Enum.Font.SourceSans; opt.TextSize = 13; opt.Text = "    " .. tostring(val.Text or val); opt.TextXAlignment = Enum.TextXAlignment.Left; opt.LayoutOrder = i; opt.Parent = dropListFrame
            opt.MouseEnter:Connect(function() ApplicaTween(opt, 0.15, {BackgroundColor3 = Color3.fromRGB(16, 26, 22), TextColor3 = Color3.fromRGB(255, 255, 255)}) end)
            opt.MouseLeave:Connect(function() ApplicaTween(opt, 0.15, {BackgroundColor3 = Color3.fromRGB(14, 14, 16), TextColor3 = Color3.fromRGB(200, 200, 205)}) end)
            opt.Activated:Connect(function()
                currentSelectedText = tostring(val.Text or val); dropBtn.Text = "  " .. currentSelectedText:upper() .. "  ▼"; dropListFrame.Visible = false; dropListFrame.Size = UDim2.new(1, 0, 0, 0); dropContainer.Size = UDim2.new(0.95, 0, 0, 35)
                InterfacciaEngine.activeDropdownFrame = nil; InterfacciaEngine.activeDropdownContainer = nil; InterfacciaEngine.activeDropdownButton = nil
                callback(val.Value or val)
            end)
        end

        dropBtn.Activated:Connect(function()
            if dropListFrame.Visible then
                dropBtn.Text = "  " .. currentSelectedText:upper() .. "  ▼"; dropListFrame.Visible = false; dropListFrame.Size = UDim2.new(1, 0, 0, 0); dropContainer.Size = UDim2.new(0.95, 0, 0, 35)
                InterfacciaEngine.activeDropdownFrame = nil; InterfacciaEngine.activeDropdownContainer = nil; InterfacciaEngine.activeDropdownButton = nil
            else
                if InterfacciaEngine.activeDropdownFrame and InterfacciaEngine.activeDropdownFrame ~= dropListFrame then
                    InterfacciaEngine.activeDropdownButton.Text = "  " .. InterfacciaEngine.activeDropdownText:upper() .. "  ▼"; InterfacciaEngine.activeDropdownFrame.Visible = false; InterfacciaEngine.activeDropdownFrame.Size = UDim2.new(1, 0, 0, 0); InterfacciaEngine.activeDropdownContainer.Size = UDim2.new(0.95, 0, 0, 35)
                end
                dropBtn.Text = "  " .. currentSelectedText:upper() .. "  ▲"; dropListFrame.Visible = true
                local altezzaLista = math.min(#options * 30, 120)
                dropListFrame.Size = UDim2.new(1, 0, 0, altezzaLista); dropContainer.Size = UDim2.new(0.95, 0, 0, 35 + altezzaLista + 5)
                InterfacciaEngine.activeDropdownFrame = dropListFrame; InterfacciaEngine.activeDropdownContainer = dropContainer; InterfacciaEngine.activeDropdownButton = dropBtn; InterfacciaEngine.activeDropdownText = currentSelectedText
            end
        end)
    end

    return InterfacciaEngine
end

