    function InterfacciaEngine:AggiungiToggle(parentTab, titleText, descText, defaultState, callback)
        local c = Instance.new("Frame", parentTab)
        c.Size, c.BackgroundColor3 = UDim2.new(0.95, 0, 0, 48), Color3.fromRGB(22, 22, 22)
        addDecor(c, 6, Color3.fromRGB(40, 40, 40))

        local tl = Instance.new("TextLabel", c)
        tl.Size, tl.Position, tl.BackgroundTransparency, tl.TextColor3, tl.Font, tl.TextSize, tl.TextXAlignment, tl.Text = UDim2.new(0.7, 0, 0, 20), UDim2.new(0, 10, 0, 5), 1, Color3.fromRGB(255, 255, 255), Enum.Font.SourceSansSemibold, 13, Enum.TextXAlignment.Left, titleText

        local dl = Instance.new("TextLabel", c)
        dl.Size, dl.Position, dl.BackgroundTransparency, dl.TextColor3, dl.Font, dl.TextSize, dl.TextXAlignment, dl.Text = UDim2.new(0.7, 0, 0, 18), UDim2.new(0, 10, 0, 23), 1, Color3.fromRGB(140, 140, 140), Enum.Font.SourceSans, 11, Enum.TextXAlignment.Left, descText

        local tBg = Instance.new("Frame", c)
        tBg.Size, tBg.Position, tBg.BackgroundColor3 = UDim2.new(0, 42, 0, 22), UDim2.new(1, -52, 0.5, -11), Color3.fromRGB(40, 40, 40)
        addDecor(tBg, 11)

        local tBall = Instance.new("Frame", tBg)
        tBall.Size, tBall.Position, tBall.BackgroundColor3 = UDim2.new(0, 16, 0, 16), UDim2.new(0, 3, 0, 3), Color3.fromRGB(120, 120, 120)
        addDecor(tBall, 8)

        local btn = Instance.new("TextButton", c)
        btn.Size, btn.BackgroundTransparency, btn.Text = UDim2.new(1, 0, 1, 0), 1, ""

        local state = defaultState
        local function up()
            tBg.BackgroundColor3 = state and Color3.fromRGB(150, 255, 0) or Color3.fromRGB(40, 40, 40)
            tBall.Position = state and UDim2.new(0, 23, 0, 3) or UDim2.new(0, 3, 0, 3)
            tBall.BackgroundColor3 = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(120, 120, 120)
        end
        up()
        btn.MouseButton1Click:Connect(function() state = not state up() callback(state) end)
        return c
    end

    function InterfacciaEngine:AggiungiDropdown(parentTab, options, defaultText, callback)
        local dropContainer = Instance.new("Frame", parentTab)
        dropContainer.Size, dropContainer.BackgroundTransparency, dropContainer.ClipsDescendants = UDim2.new(0.95, 0, 0, 35), 1, true

        local dropBtn = Instance.new("TextButton", dropContainer)
        dropBtn.Size, dropBtn.BackgroundColor3, dropBtn.TextColor3, dropBtn.Font, dropBtn.TextSize, dropBtn.Text, dropBtn.TextXAlignment = UDim2.new(1, 0, 0, 35), Color3.fromRGB(22, 22, 22), Color3.fromRGB(150, 255, 0), Enum.Font.SourceSansBold, 13, defaultText:upper().." ▼", Enum.TextXAlignment.Left
        addDecor(dropBtn, 6, Color3.fromRGB(50, 50, 50))

        local dList = Instance.new("ScrollingFrame", dropContainer)
        dList.Name, dList.Size, dList.Position, dList.BackgroundColor3, dList.Visible, dList.ScrollBarThickness, dList.ScrollBarImageColor3, dList.CanvasSize = "DropList", UDim2.new(1, 0, 0, 0), UDim2.new(0, 0, 0, 38), Color3.fromRGB(18, 18, 18), false, 3, Color3.fromRGB(150, 255, 0), UDim2.new(0, 0, 0, #options * 30)
        addDecor(dList, 6, Color3.fromRGB(150, 255, 0))
        Instance.new("UIListLayout", dList).SortOrder = Enum.SortOrder.LayoutOrder

        for i, val in ipairs(options) do
            local opt = Instance.new("TextButton", dList)
            opt.Size, opt.BackgroundColor3, opt.TextColor3, opt.Font, opt.TextSize, opt.Text, opt.TextXAlignment, opt.LayoutOrder = UDim2.new(1, 0, 0, 30), Color3.fromRGB(25, 25, 25), Color3.fromRGB(255, 255, 255), Enum.Font.SourceSans, 12, tostring(val.Text or val), Enum.TextXAlignment.Left, i
            opt.Activated:Connect(function()
                dropBtn.Text = tostring(val.Text or val):upper() .. " ▼"
                dList.Visible, dList.Size, dropContainer.Size = false, UDim2.new(1, 0, 0, 0), UDim2.new(0.95, 0, 0, 35)
                InterfacciaEngine.activeDropdownFrame, InterfacciaEngine.activeDropdownContainer = nil, nil
                callback(val.Value or val)
            end)
        end

        dropBtn.Activated:Connect(function()
            if dList.Visible then
                dList.Visible, dList.Size, dropContainer.Size = false, UDim2.new(1, 0, 0, 0), UDim2.new(0.95, 0, 0, 35)
                InterfacciaEngine.activeDropdownFrame, InterfacciaEngine.activeDropdownContainer = nil, nil
            else
                if InterfacciaEngine.activeDropdownFrame and InterfacciaEngine.activeDropdownFrame ~= dList then
                    InterfacciaEngine.activeDropdownFrame.Visible, InterfacciaEngine.activeDropdownFrame.Size, InterfacciaEngine.activeDropdownContainer.Size = false, UDim2.new(1, 0, 0, 0), UDim2.new(0.95, 0, 0, 35)
                end
                dList.Visible = true
                local h = math.min(#options * 30, 120)
                dList.Size, dropContainer.Size = UDim2.new(1, 0, 0, h), UDim2.new(0.95, 0, 0, 35 + h + 5)
                InterfacciaEngine.activeDropdownFrame, InterfacciaEngine.activeDropdownContainer = dList, dropContainer
            end
        end)
    end

    function InterfacciaEngine:AggiungiSlider(parentTab, titleText, min, max, default, callback)
        local c = Instance.new("Frame", parentTab)
        c.Size, c.BackgroundColor3 = UDim2.new(0.95, 0, 0, 50), Color3.fromRGB(22, 22, 22)
        addDecor(c, 6)

        local tl = Instance.new("TextLabel", c)
        tl.Size, tl.Position, tl.BackgroundTransparency, tl.TextColor3, tl.Font, tl.TextSize, tl.TextXAlignment, tl.Text = UDim2.new(0.7, 0, 0, 20), UDim2.new(0, 10, 0, 5), 1, Color3.fromRGB(255, 255, 255), Enum.Font.SourceSansSemibold, 13, Enum.TextXAlignment.Left, titleText

        local vl = Instance.new("TextLabel", c)
        vl.Size, vl.Position, vl.BackgroundTransparency, vl.TextColor3, vl.Font, tl.TextSize, vl.TextXAlignment, vl.Text = UDim2.new(0.25, 0, 0, 20), UDim2.new(0.7, 10, 0, 5), 1, Color3.fromRGB(150, 255, 0), Enum.Font.SourceSansBold, 13, Enum.TextXAlignment.Right, tostring(default)

        local sBg = Instance.new("Frame", c)
        sBg.Size, sBg.Position, sBg.BackgroundColor3 = UDim2.new(0.9, 0, 0, 6), UDim2.new(0.05, 0, 0.7, 0), Color3.fromRGB(40, 40, 40)
        addDecor(sBg, 3)

        local sFill = Instance.new("Frame", sBg)
        sFill.Size, sFill.BackgroundColor3 = UDim2.new(math.clamp((default - min) / (max - min), 0, 1), 0, 1, 0), Color3.fromRGB(150, 255, 0)
        addDecor(sFill, 3)

        local dragging = false
        local function update(input)
            local pct = math.clamp((input.Position.X - sBg.AbsolutePosition.X) / sBg.AbsoluteSize.X, 0, 1)
            sFill.Size = UDim2.new(pct, 0, 1, 0)
            local val = math.floor(min + ((max - min) * pct))
            vl.Text = tostring(val)
            callback(val)
        end

        sBg.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true update(input) end
        end)
        UIS.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then update(input) end
        end)
        UIS.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
        end)
        return c
    end

    function InterfacciaEngine:AggiungiTextBox(parentTab, titleText, placeholderText, callback)
        local c = Instance.new("Frame", parentTab)
        c.Size, c.BackgroundColor3 = UDim2.new(0.95, 0, 0, 45), Color3.fromRGB(22, 22, 22)
        addDecor(c, 6)

        local tl = Instance.new("TextLabel", c)
        tl.Size, tl.Position, tl.BackgroundTransparency, tl.TextColor3, tl.Font, tl.TextSize, tl.TextXAlignment, tl.Text = UDim2.new(0.4, 0, 1, 0), UDim2.new(0, 10, 0, 0), 1, Color3.fromRGB(255, 255, 255), Enum.Font.SourceSansSemibold, 13, Enum.TextXAlignment.Left, titleText

        local boxContainer = Instance.new("Frame", c)
        boxContainer.Size, boxContainer.Position, boxContainer.BackgroundColor3 = UDim2.new(0.5, 0, 0, 26), UDim2.new(0.5, -10, 0.5, -13), Color3.fromRGB(30, 30, 30)
        addDecor(boxContainer, 4)

        local tb = Instance.new("TextBox", boxContainer)
        tb.Size, tb.Position, tb.BackgroundTransparency, tb.TextColor3, tb.PlaceholderColor3, tb.PlaceholderText, tb.Text, tb.Font, tb.TextSize, tb.TextXAlignment, tb.ClearTextOnFocus = UDim2.new(1, -10, 1, 0), UDim2.new(0, 5, 0, 0), 1, Color3.fromRGB(255, 255, 255), Color3.fromRGB(120, 120, 120), placeholderText, "", Enum.Font.SourceSans, 12, Enum.TextXAlignment.Left, false
        tb.FocusLost:Connect(function(ep) callback(tb.Text, ep) end)
