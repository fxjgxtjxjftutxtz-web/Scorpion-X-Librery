-- =============================================================================
-- SCORPION X - UI LIBRARY ENGINE (FIXED GLITCH & ACID GREEN EDITION)
-- =============================================================================
local Library = {}

function Library:Inizializza(titoloHub)
    local Players = game:GetService("Players")
    local CoreGui = game:GetService("CoreGui")
    local player = Players.LocalPlayer
    local playerGui = player:WaitForChild("PlayerGui", 10) or player.PlayerGui

    local oldGui = playerGui:FindFirstChild("ScorpioXMenu") or CoreGui:FindFirstChild("ScorpioXMenu")
    if oldGui then oldGui:Destroy() end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "ScorpioXMenu"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.DisplayOrder = 100

    local successo = pcall(function() ScreenGui.Parent = CoreGui end)
    if not successo then ScreenGui.Parent = playerGui end

    -- MAIN FRAME: Sfondo Nero/Grigio Scuro
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(0, 520, 0, 340)
    MainFrame.Position = UDim2.new(0.5, -260, 0.5, -170)
    MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15) -- Nero profondo
    MainFrame.Active = true
    MainFrame.Draggable = true
    MainFrame.Visible = true
    MainFrame.Parent = ScreenGui

    local UICornerFrame = Instance.new("UICorner")
    UICornerFrame.CornerRadius = UDim.new(0, 10)
    UICornerFrame.Parent = MainFrame

    -- BORDUURA: Verde Acido
    local UIStrokeFrame = Instance.new("UIStroke")
    UIStrokeFrame.Thickness = 1.5
    UIStrokeFrame.Color = Color3.fromRGB(150, 255, 0) -- Verde Acido
    UIStrokeFrame.Parent = MainFrame

    local TopBar = Instance.new("Frame")
    TopBar.Name = "TopBar"
    TopBar.Size = UDim2.new(1, 0, 0, 35)
    TopBar.BackgroundColor3 = Color3.fromRGB(25, 25, 25) -- Grigio Scuro
    TopBar.Parent = MainFrame

    local TopBarCorner = Instance.new("UICorner")
    TopBarCorner.CornerRadius = UDim.new(0, 10)
    TopBarCorner.Parent = TopBar

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size = UDim2.new(1, -20, 1, 0)
    TitleLabel.Position = UDim2.new(0, 15, 0, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- Bianco
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextSize = 14
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.Text = tostring(titoloHub):upper()
    TitleLabel.Parent = TopBar

    -- BOTTONE DI APERTURA (SCO X)
    local ToggleMenuBtn = Instance.new("TextButton")
    ToggleMenuBtn.Name = "ToggleMenuBtn"
    ToggleMenuBtn.Size = UDim2.new(0, 60, 0, 60)
    ToggleMenuBtn.Position = UDim2.new(0, 20, 0.3, 0)
    ToggleMenuBtn.BackgroundColor3 = Color3.fromRGB(150, 255, 0) -- Verde Acido
    ToggleMenuBtn.TextColor3 = Color3.fromRGB(0, 0, 0) -- Testo Nero per contrasto
    ToggleMenuBtn.Font = Enum.Font.GothamBold
    ToggleMenuBtn.TextSize = 12
    ToggleMenuBtn.Text = "SCO X"
    ToggleMenuBtn.Parent = ScreenGui

    local UICornerBtn = Instance.new("UICorner")
    UICornerBtn.CornerRadius = UDim.new(1, 0)
    UICornerBtn.Parent = ToggleMenuBtn

    ToggleMenuBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = not MainFrame.Visible
    end)

    local SideBar = Instance.new("ScrollingFrame")
    SideBar.Name = "SideBar"
    SideBar.Size = UDim2.new(0, 130, 0, 285)
    SideBar.Position = UDim2.new(0, 10, 0, 45)
    SideBar.BackgroundTransparency = 1
    SideBar.CanvasSize = UDim2.new(0, 0, 0, 400)
    SideBar.ScrollBarThickness = 0
    SideBar.Parent = MainFrame

    local SideBarList = Instance.new("UIListLayout")
    SideBarList.Padding = UDim.new(0, 5)
    SideBarList.SortOrder = Enum.SortOrder.LayoutOrder
    SideBarList.Parent = SideBar

    local ContentContainer = Instance.new("Frame")
    ContentContainer.Name = "ContentContainer"
    ContentContainer.Size = UDim2.new(0, 360, 0, 285)
    ContentContainer.Position = UDim2.new(0, 150, 0, 45)
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Parent = MainFrame

    local InterfacciaEngine = { tabs = {}, tabButtons = {}, primaTab = nil }

    function InterfacciaEngine:CreaTab(name, order)
        local contentFrame = Instance.new("ScrollingFrame")
        contentFrame.Name = name .. "Tab"
        contentFrame.Size = UDim2.new(1, 0, 1, 0)
        contentFrame.BackgroundTransparency = 1
        contentFrame.CanvasSize = UDim2.new(0, 0, 0, 500)
        contentFrame.ScrollBarThickness = 4
        contentFrame.ScrollBarImageColor3 = Color3.fromRGB(150, 255, 0) -- Sbarra Verde Acido
        contentFrame.Visible = false
        contentFrame.Parent = ContentContainer

        local listLayout = Instance.new("UIListLayout")
        listLayout.Padding = UDim.new(0, 6)
        listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        listLayout.SortOrder = Enum.SortOrder.LayoutOrder
        listLayout.Parent = contentFrame

        listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            contentFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 20)
        end)

        self.tabs[name] = contentFrame

        local tabBtn = Instance.new("TextButton")
        tabBtn.Size = UDim2.new(0, 120, 0, 32)
        tabBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25) -- Grigio Scuro
        tabBtn.TextColor3 = Color3.fromRGB(180, 180, 180) -- Grigio Chiaro
        tabBtn.Font = Enum.Font.GothamSemibold
        tabBtn.TextSize = 12
        tabBtn.Text = " " .. name
        tabBtn.TextXAlignment = Enum.TextXAlignment.Left
        tabBtn.LayoutOrder = order
        tabBtn.Parent = SideBar

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 6)
        btnCorner.Parent = tabBtn
        
        local btnStroke = Instance.new("UIStroke")
        btnStroke.Thickness = 1
        btnStroke.Color = Color3.fromRGB(40, 40, 40)
        btnStroke.Parent = tabBtn

        if not self.primaTab then
            self.primaTab = name
        end

        tabBtn.MouseButton1Click:Connect(function()
            for tName, frame in pairs(self.tabs) do 
                frame.Visible = (tName == name) 
            end
            for bName, btn in pairs(self.tabButtons) do
                if bName == name then
                    btn.BackgroundColor3 = Color3.fromRGB(150, 255, 0) -- Attivo: Verde Acido
                    btn.TextColor3 = Color3.fromRGB(0, 0, 0) -- Attivo: Nero
                    btn.UIStroke.Color = Color3.fromRGB(200, 255, 100)
                else
                    btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25) -- Spento: Grigio
                    btn.TextColor3 = Color3.fromRGB(180, 180, 180) -- Spento: Grigio chiaro
                    btn.UIStroke.Color = Color3.fromRGB(40, 40, 40)
                end
            end
        end)

        self.tabButtons[name] = tabBtn
        return contentFrame
    end

    function InterfacciaEngine:AggiungiToggle(parentTab, titleText, descText, defaultState, callback)
        local container = Instance.new("Frame")
        container.Size = UDim2.new(0.95, 0, 0, 48)
        container.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
        container.Parent = parentTab

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 6)
        corner.Parent = container
        
        local stroke = Instance.new("UIStroke")
        stroke.Thickness = 1
        stroke.Color = Color3.fromRGB(40, 40, 40)
        stroke.Parent = container

        local titleLabel = Instance.new("TextLabel")
        titleLabel.Size = UDim2.new(0.7, 0, 0, 20)
        titleLabel.Position = UDim2.new(0, 10, 0, 5)
        titleLabel.BackgroundTransparency = 1
        titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- Bianco
        titleLabel.Font = Enum.Font.GothamMedium
        titleLabel.TextSize = 13
        titleLabel.TextXAlignment = Enum.TextXAlignment.Left
        titleLabel.Text = titleText
        titleLabel.Parent = container

        local descLabel = Instance.new("TextLabel")
        descLabel.Size = UDim2.new(0.7, 0, 0, 18)
        descLabel.Position = UDim2.new(0, 10, 0, 23)
        descLabel.BackgroundTransparency = 1
        descLabel.TextColor3 = Color3.fromRGB(150, 150, 150) -- Grigio
        descLabel.Font = Enum.Font.Gotham
        descLabel.TextSize = 10
        descLabel.TextXAlignment = Enum.TextXAlignment.Left
        descLabel.Text = descText
        descLabel.Parent = container

        local toggleBg = Instance.new("Frame")
        toggleBg.Size = UDim2.new(0, 42, 0, 22)
        toggleBg.Position = UDim2.new(1, -52, 0.5, -11)
        toggleBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        toggleBg.Parent = container

        local toggleBgCorner = Instance.new("UICorner")
        toggleBgCorner.CornerRadius = UDim.new(1, 0)
        toggleBgCorner.Parent = toggleBg

        local toggleBall = Instance.new("Frame")
        toggleBall.Size = UDim2.new(0, 16, 0, 16)
        toggleBall.Position = UDim2.new(0, 3, 0, 3)
        toggleBall.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        toggleBall.Parent = toggleBg

        local toggleBallCorner = Instance.new("UICorner")
        toggleBallCorner.CornerRadius = UDim.new(1, 0)
        toggleBallCorner.Parent = toggleBall

        local clickBtn = Instance.new("TextButton")
        clickBtn.Size = UDim2.new(1, 0, 1, 0)
        clickBtn.BackgroundTransparency = 1
        clickBtn.Text = ""
        clickBtn.Parent = container

        local state = defaultState
        local function updateVisual()
            -- Attivo: Sfondo Verde Acido, Pallina Bianca | Spento: Grigio/Nero
            toggleBg.BackgroundColor3 = state and Color3.fromRGB(150, 255, 0) or Color3.fromRGB(40, 40, 40)
            toggleBall.Position = state and UDim2.new(0, 23, 0, 3) or UDim2.new(0, 3, 0, 3)
            toggleBall.BackgroundColor3 = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(120, 120, 120)
        end

        updateVisual()
        clickBtn.MouseButton1Click:Connect(function()
            state = not state
            updateVisual()
            callback(state)
        end)

        return container
    end

    function InterfacciaEngine:AggiungiDropdown(parentTab, options, defaultText, callback)
        -- Usiamo ClipsDescendants = false sul container per permettere alla lista di uscire senza glitchare
        local dropContainer = Instance.new("Frame")
        dropContainer.Size = UDim2.new(0.95, 0, 0, 35)
        dropContainer.BackgroundTransparency = 1
        dropContainer.ClipsDescendants = false 
        dropContainer.Parent = parentTab

        local dropBtn = Instance.new("TextButton")
        dropBtn.Size = UDim2.new(1, 0, 1, 0)
        dropBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        dropBtn.TextColor3 = Color3.fromRGB(150, 255, 0) -- Testo Verde Acido
        dropBtn.Font = Enum.Font.GothamBold
        dropBtn.TextSize = 12
        dropBtn.Text = "  " .. defaultText .. "  ▼"
        dropBtn.TextXAlignment = Enum.TextXAlignment.Left
        dropBtn.ZIndex = 10 -- Alza il bottone primario
        dropBtn.Parent = dropContainer

        local dropCorner = Instance.new("UICorner")
        dropCorner.CornerRadius = UDim.new(0, 6)
        dropCorner.Parent = dropBtn
        
        local dropStroke = Instance.new("UIStroke")
        dropStroke.Thickness = 1
        dropStroke.Color = Color3.fromRGB(150, 255, 0) -- Bordo Verde Acido
        dropStroke.Parent = dropBtn

        local dropListFrame = Instance.new("Frame")
        dropListFrame.Size = UDim2.new(1, 0, 0, 0)
        dropListFrame.Position = UDim2.new(0, 0, 1, 3)
        dropListFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15) -- Sfondo nero lista
        dropListFrame.Visible = false
        dropListFrame.ZIndex = 50 -- Valore alto per sovrapporsi ai toggle sottostanti (Risolve il Glitch!)
        dropListFrame.Parent = dropContainer
        
        local dCorner = Instance.new("UICorner")
        dCorner.CornerRadius = UDim.new(0, 6)
        dCorner.Parent = dropListFrame

        local dropLayout = Instance.new("UIListLayout")
        dropLayout.Parent = dropListFrame

        for _, val in ipairs(options) do
            local opt = Instance.new("TextButton")
            opt.Size = UDim2.new(1, 0, 0, 30)
            opt.BackgroundColor3 = Color3.fromRGB(30, 30, 30) -- Elementi grigi
            opt.TextColor3 = Color3.fromRGB(255, 255, 255) -- Scritta bianca
            opt.Font = Enum.Font.Gotham
            opt.TextSize = 11
            opt.Text = "   " .. tostring(val.Text or val)
            opt.TextXAlignment = Enum.TextXAlignment.Left
            opt.ZIndex = 51 -- Sopra il frame della lista
            opt.Parent = dropListFrame

            opt.Activated:Connect(function()
                dropBtn.Text = "  " .. tostring(val.Text or val) .. "  ▼"
                dropListFrame.Visible = false
                dropContainer.Size = UDim2.new(0.95, 0, 0, 35)
                callback(val.Value or val)
            end)
        end

        dropBtn.Activated:Connect(function()
            dropListFrame.Visible = not dropListFrame.Visible
            if dropListFrame.Visible then
                dropListFrame.Size = UDim2.new(1, 0, 0, #options * 30)
                -- Modifica della dimensione del container per non rompere il layout UIListLayout del tab padre
                dropContainer.Size = UDim2.new(0.95, 0, 0, 35 + (#options * 30) + 5)
            else
                dropContainer.Size = UDim2.new(0.95, 0, 0, 35)
            end
        end)
    end

    task.spawn(function()
        task.wait(0.5)
        if self.primaTab and self.tabs[self.primaTab] then
            self.tabs[self.primaTab].Visible = true
            local btn = self.tabButtons[self.primaTab]
            if btn then
                btn.BackgroundColor3 = Color3.fromRGB(150, 255, 0)
                btn.TextColor3 = Color3.fromRGB(0, 0, 0)
                btn.UIStroke.Color = Color3.fromRGB(200, 255, 100)
            end
        end
    end)

    return InterfacciaEngine
end

return Library
