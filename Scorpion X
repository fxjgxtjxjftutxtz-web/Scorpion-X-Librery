    function InterfacciaEngine:CreaTab(name, order)
        local contentFrame = Instance.new("ScrollingFrame")
        contentFrame.Name = name .. "Tab"
        contentFrame.Size = UDim2.new(1, 0, 1, 0)
        contentFrame.BackgroundTransparency = 1
        contentFrame.CanvasSize = UDim2.new(0, 0, 0, 500)
        contentFrame.ScrollBarThickness = 2
        contentFrame.ScrollBarImageColor3 = Color3.fromRGB(40, 40, 45)
        contentFrame.Visible = false
        contentFrame.ClipsDescendants = true
        contentFrame.Parent = ContentContainer

        local listLayout = Instance.new("UIListLayout")
        listLayout.Padding = UDim.new(0, 8)
        listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        listLayout.SortOrder = Enum.SortOrder.LayoutOrder
        listLayout.Parent = contentFrame

        listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            contentFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 20)
        end)

        InterfacciaEngine.tabs[name] = contentFrame

        local tabBtn = Instance.new("TextButton")
        tabBtn.Size = UDim2.new(1, 0, 0, 34)
        tabBtn.BackgroundColor3 = Color3.fromRGB(18, 18, 20)
        tabBtn.TextColor3 = Color3.fromRGB(140, 140, 145)
        tabBtn.Font = Enum.Font.GothamSemibold
        tabBtn.TextSize = 12
        tabBtn.Text = name
        tabBtn.LayoutOrder = order or 0
        tabBtn.Parent = SideBar

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 6)
        btnCorner.Parent = tabBtn
        
        local btnStroke = Instance.new("UIStroke")
        btnStroke.Thickness = 1
        btnStroke.Color = Color3.fromRGB(26, 26, 28)
        btnStroke.Parent = tabBtn

        -- FORZA l'apertura se è la prima tab assoluta
        if not InterfacciaEngine.primaTab then 
            InterfacciaEngine.primaTab = name 
            contentFrame.Visible = true
            tabBtn.BackgroundColor3 = Color3.fromRGB(16, 26, 22)
            tabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btnStroke.Color = VerdeTema
        end

        tabBtn.MouseEnter:Connect(function()
            if InterfacciaEngine.tabButtons[name].TextColor3 ~= Color3.fromRGB(255, 255, 255) then
                ApplicaTween(tabBtn, 0.2, {BackgroundColor3 = Color3.fromRGB(24, 24, 27), TextColor3 = Color3.fromRGB(200, 200, 205)})
            end
        end)
        
        tabBtn.MouseLeave:Connect(function()
            if InterfacciaEngine.tabButtons[name].TextColor3 ~= Color3.fromRGB(255, 255, 255) then
                ApplicaTween(tabBtn, 0.2, {BackgroundColor3 = Color3.fromRGB(18, 18, 20), TextColor3 = Color3.fromRGB(140, 140, 145)})
            end
        end)

        tabBtn.MouseButton1Click:Connect(function()
            if InterfacciaEngine.activeDropdownFrame then
                InterfacciaEngine.activeDropdownButton.Text = "  " .. InterfacciaEngine.activeDropdownText:upper() .. "  ▼"
                InterfacciaEngine.activeDropdownFrame.Visible = false
                InterfacciaEngine.activeDropdownFrame.Size = UDim2.new(1, 0, 0, 0)
                InterfacciaEngine.activeDropdownContainer.Size = UDim2.new(0.95, 0, 0, 35)
                InterfacciaEngine.activeDropdownFrame = nil
                InterfacciaEngine.activeDropdownContainer = nil
            end
            for tName, frame in pairs(InterfacciaEngine.tabs) do frame.Visible = (tName == name) end
            for bName, btn in pairs(InterfacciaEngine.tabButtons) do
                if bName == name then
                    ApplicaTween(btn, 0.15, {BackgroundColor3 = Color3.fromRGB(16, 26, 22), TextColor3 = Color3.fromRGB(255, 255, 255)})
                    btn.UIStroke.Color = VerdeTema
                else
                    ApplicaTween(btn, 0.15, {BackgroundColor3 = Color3.fromRGB(18, 18, 20), TextColor3 = Color3.fromRGB(140, 140, 145)})
                    btn.UIStroke.Color = Color3.fromRGB(26, 26, 28)
                end
            end
        end)

        InterfacciaEngine.tabButtons[name] = tabBtn
        return contentFrame
    end

