        btn.Size, btn.BackgroundColor3, btn.TextColor3, btn.Font, btn.TextSize, btn.Text = UDim2.new(0.95, 0, 0, 32), Color3.fromRGB(22, 22, 22), Color3.fromRGB(255, 255, 255), Enum.Font.SourceSansSemibold, 13, text
