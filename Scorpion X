        local l = Instance.new("TextLabel", c)
        l.Size, l.BackgroundTransparency, l.TextColor3, l.Font, l.TextSize, l.TextXAlignment, l.Text = UDim2.new(1, 0, 1, 0), 1, Color3.fromRGB(150, 255, 0), Enum.Font.SourceSansBold, 11, Enum.TextXAlignment.Left, text:upper()
