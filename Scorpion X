local Library = {}

local function addDecor(inst, radius, strokeColor, thickness)
    if radius then local c = Instance.new("UICorner") c.CornerRadius = UDim.new(0, radius) c.Parent = inst end
    if strokeColor then local s = Instance.new("UIStroke") s.Thickness = thickness or 1 s.Color = strokeColor s.Parent = inst return s end
end

function Library:Inizializza(titoloHub, idIconaPulsante, tastoChiusuraDefault)
    local Players, CoreGui, UIS, Tweens = game:GetService("Players"), game:GetService("CoreGui"), game:GetService("UserInputService"), game:GetService("TweenService")
    local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui", 10) or Players.LocalPlayer.PlayerGui

    local oldGui = playerGui:FindFirstChild("ScorpioXMenu") or CoreGui:FindFirstChild("ScorpioXMenu")
    if oldGui then oldGui:Destroy() end

    local ScreenGui = Instance.new("ScreenGui", pcall(function() ScreenGui.Parent = CoreGui end) and CoreGui or playerGui)
    ScreenGui.Name, ScreenGui.ResetOnSpawn, ScreenGui.DisplayOrder = "ScorpioXMenu", false, 100

    local MainFrame = Instance.new("Frame", ScreenGui)
    MainFrame.Name, MainFrame.Size, MainFrame.Position, MainFrame.BackgroundColor3, MainFrame.Active, MainFrame.Draggable = "MainFrame", UDim2.new(0, 520, 0, 340), UDim2.new(0.5, -260, 0.5, -170), Color3.fromRGB(15, 15, 15), true, true
    addDecor(MainFrame, 10, Color3.fromRGB(150, 255, 0), 1.5)

    local TopBar = Instance.new("Frame", MainFrame)
    TopBar.Name, TopBar.Size, TopBar.BackgroundColor3 = "TopBar", UDim2.new(1, 0, 0, 35), Color3.fromRGB(22, 22, 22)
    addDecor(TopBar, 10)

    local TitleLabel = Instance.new("TextLabel", TopBar)
    TitleLabel.Size, TitleLabel.Position, TitleLabel.BackgroundTransparency, TitleLabel.TextColor3, TitleLabel.Font, TitleLabel.TextSize, TitleLabel.TextXAlignment, TitleLabel.Text = UDim2.new(1, -20, 1, 0), UDim2.new(0, 15, 0, 0), 1, Color3.fromRGB(255, 255, 255), Enum.Font.SourceSansBold, 14, Enum.TextXAlignment.Left, tostring(titoloHub):upper()

    local ToggleMenuBtn
    if idIconaPulsante and idIconaPulsante ~= "" then
        ToggleMenuBtn = Instance.new("ImageButton")
        ToggleMenuBtn.Image, ToggleMenuBtn.ScaleType, ToggleMenuBtn.BackgroundColor3 = "rbxassetid://" .. tostring(idIconaPulsante):match("%d+"), Enum.ScaleType.Crop, Color3.fromRGB(15, 15, 15)
    else
        ToggleMenuBtn = Instance.new("TextButton")
        ToggleMenuBtn.Text, ToggleMenuBtn.TextColor3, ToggleMenuBtn.Font, ToggleMenuBtn.TextSize, ToggleMenuBtn.BackgroundColor3 = "SCO X", Color3.fromRGB(150, 255, 0), Enum.Font.SourceSansBold, 14, Color3.fromRGB(15, 15, 15)
    end
    ToggleMenuBtn.Name, ToggleMenuBtn.Size, ToggleMenuBtn.Position, ToggleMenuBtn.Active, ToggleMenuBtn.Draggable, ToggleMenuBtn.Parent = "ToggleMenuBtn", UDim2.new(0, 50, 0, 50), UDim2.new(0, 20, 0.3, 0), true, true, ScreenGui
    addDecor(ToggleMenuBtn, 25, Color3.fromRGB(150, 255, 0), 1.5)
    ToggleMenuBtn.MouseButton1Click:Connect(function() MainFrame.Visible = not MainFrame.Visible end)

    UIS.InputBegan:Connect(function(input, processed)
        if not processed and input.KeyCode == (tastoChiusuraDefault or Enum.KeyCode.RightControl) then MainFrame.Visible = not MainFrame.Visible end
    end)

    local SideBar = Instance.new("ScrollingFrame", MainFrame)
    SideBar.Name, SideBar.Size, SideBar.Position, SideBar.BackgroundTransparency, SideBar.CanvasSize, SideBar.ScrollBarThickness = "SideBar", UDim2.new(0, 130, 0, 285), UDim2.new(0, 10, 0, 45), 1, UDim2.new(0, 0, 0, 400), 0
    
    local SideBarList = Instance.new("UIListLayout", SideBar)
    SideBarList.Padding, SideBarList.SortOrder = UDim.new(0, 5), Enum.SortOrder.LayoutOrder

    local ContentContainer = Instance.new("Frame", MainFrame)
    ContentContainer.Name, ContentContainer.Size, ContentContainer.Position, ContentContainer.BackgroundTransparency = "ContentContainer", UDim2.new(0, 360, 0, 285), UDim2.new(0, 150, 0, 45), 1

    local InterfacciaEngine = { tabs = {}, tabButtons = {}, primaTab = nil, activeDropdownContainer = nil, activeDropdownFrame = nil }

    function Library:Notifica(titolo, messaggio, durata)
        local Storage = ScreenGui:FindFirstChild("NotificationStorage") or Instance.new("Frame", ScreenGui)
        if not ScreenGui:FindFirstChild("NotificationStorage") then
            Storage.Name, Storage.Size, Storage.Position, Storage.BackgroundTransparency = "NotificationStorage", UDim2.new(0, 250, 0, 400), UDim2.new(1, -260, 1, -410), 1
            Instance.new("UIListLayout", Storage).VerticalAlignment = Enum.VerticalAlignment.Bottom
            Storage.UIListLayout.Padding = UDim.new(0, 8)
        end

        local NotifFrame = Instance.new("Frame", Storage)
        NotifFrame.Size, NotifFrame.BackgroundColor3 = UDim2.new(1, 0, 0, 60), Color3.fromRGB(20, 20, 20)
        local stroke = addDecor(NotifFrame, 6, Color3.fromRGB(150, 255, 0))

        local tl = Instance.new("TextLabel", NotifFrame)
        tl.Size, tl.Position, tl.BackgroundTransparency, tl.TextColor3, tl.Font, tl.TextSize, tl.TextXAlignment, tl.Text = UDim2.new(1, -20, 0, 20), UDim2.new(0, 10, 0, 5), 1, Color3.fromRGB(150, 255, 0), Enum.Font.SourceSansBold, 13, Enum.TextXAlignment.Left, titolo:upper()
        
        local ml = Instance.new("TextLabel", NotifFrame)
        ml.Size, ml.Position, ml.BackgroundTransparency, ml.TextColor3, ml.Font, ml.TextSize, ml.TextWrapped, ml.TextXAlignment, ml.TextYAlignment, ml.Text = UDim2.new(1, -20, 0, 30), UDim2.new(0, 10, 0, 22), 1, Color3.fromRGB(255, 255, 255), Enum.Font.SourceSans, 12, true, Enum.TextXAlignment.Left, Enum.TextYAlignment.Top, messaggio

        task.spawn(function()
            task.wait(durata or 4)
            local info = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            Tweens:Create(NotifFrame, info, {BackgroundTransparency = 1}):Play()
            Tweens:Create(tl, info, {TextTransparency = 1}):Play()
            Tweens:Create(ml, info, {TextTransparency = 1}):Play()
            local sT = Tweens:Create(stroke, info, {Transparency = 1}) sT:Play()
            sT.Completed:Connect(function() NotifFrame:Destroy() end)
        end)
    end

    function InterfacciaEngine:CreaTab(name, order)
        local cf = Instance.new("ScrollingFrame", ContentContainer)
        cf.Name, cf.Size, cf.BackgroundTransparency, cf.CanvasSize, cf.ScrollBarThickness, cf.ScrollBarImageColor3, cf.Visible, cf.ClipsDescendants = name.."Tab", UDim2.new(1, 0, 1, 0), 1, UDim2.new(0, 0, 0, 500), 3, Color3.fromRGB(150, 255, 0), false, true
        
        local layout = Instance.new("UIListLayout", cf)
        layout.Padding, layout.HorizontalAlignment, layout.SortOrder = UDim.new(0, 6), Enum.HorizontalAlignment.Center, Enum.SortOrder.LayoutOrder
        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() cf.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20) end)

        self.tabs[name] = cf

        local btn = Instance.new("TextButton", SideBar)
        btn.Size, btn.BackgroundColor3, btn.TextColor3, btn.Font, btn.TextSize, btn.Text, btn.TextXAlignment, btn.LayoutOrder = UDim2.new(0, 120, 0, 32), Color3.fromRGB(25, 25, 25), Color3.fromRGB(180, 180, 180), Enum.Font.SourceSansSemibold, 13, name, Enum.TextXAlignment.Left, order
        addDecor(btn, 6, Color3.fromRGB(40, 40, 40))

        if not self.primaTab then self.primaTab = name end

        btn.MouseButton1Click:Connect(function()
            if self.activeDropdownFrame then
                self.activeDropdownFrame.Visible, self.activeDropdownFrame.Size, self.activeDropdownContainer.Size = false, UDim2.new(1, 0, 0, 0), UDim2.new(0.95, 0, 0, 35)
                self.activeDropdownFrame, self.activeDropdownContainer = nil, nil
            end
            for tName, frame in pairs(self.tabs) do frame.Visible = (tName == name) end
            for bName, tBtn in pairs(self.tabButtons) do
                tBtn.BackgroundColor3 = (bName == name) and Color3.fromRGB(150, 255, 0) or Color3.fromRGB(25, 25, 25)
                tBtn.TextColor3 = (bName == name) and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(180, 180, 180)
            end
        end)

        self.tabButtons[name] = btn
        return cf
    end

