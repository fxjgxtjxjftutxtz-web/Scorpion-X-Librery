task.spawn(function()
    local tempoBloccato = 0
    local ultimoNodoAttaccato = nil
    local timestampInizioNodo = 0
    local randomOffset = Vector3.new(0,0,0)
    
    while true do
        if farmMovementEnabled and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character:FindFirstChild("HumanoidRootPart") then
            local hum = player.Character.Humanoid
            local hrp = player.Character.HumanoidRootPart
            local node, dist = getClosestAvailableNode(player.Character)
            local srv = ReplicatedStorage:FindFirstChild("Aero") and ReplicatedStorage.Aero.AeroRemoteServices:FindFirstChild("GameService")
            
            if farmSubMode == "EXP_SHELLS" and node and not tpDelayAttivo then
                if node ~= ultimoNodoAttaccato then
                    ultimoNodoAttaccato = node
                    timestampInizioNodo = os.time()
                    randomOffset = Vector3.new(math.random(-12, 12)/10, 0, math.random(-12, 12)/10)
                else
                    if os.time() - timestampInizioNodo > 1 then
                        nodiBlacklist[node] = os.time() + 15
                        ultimoNodoAttaccato = nil
                    end
                end

                local nodoPosConOffset = node.Position + randomOffset
                local miaPos = hrp.Position
                local distanzaPiana = (Vector3.new(miaPos.X, 0, miaPos.Z) - Vector3.new(nodoPosConOffset.X, 0, nodoPosConOffset.Z)).Magnitude
                
                if distanzaPiana > PORTATA_ATTACCO_FARM then
                    hum:MoveTo(nodoPosConOffset)
                    
                    if hrp.AssemblyLinearVelocity.Magnitude < 3 then
                        tempoBloccato = tempoBloccato + 0.1
                        if tempoBloccato >= 0.4 then
                            hum.Jump = true 
                            tempoBloccato = 0
                        end
                    else
                        tempoBloccato = 0
                    end
                else
                    hum:MoveTo(miaPos)
                    tempoBloccato = 0
                end
            elseif tpDelayAttivo then
                hum:MoveTo(hrp.Position)
                tempoBloccato = 0
            end
            
            if srv then
                srv.WeaponAttackStart:FireServer()
                srv.WeaponAnimComplete:FireServer()
            end
            task.wait(ATTACK_DELAY)
        else 
            tempoBloccato = 0
            ultimoNodoAttaccato = nil
            task.wait(0.4)
        end
    end
end)

