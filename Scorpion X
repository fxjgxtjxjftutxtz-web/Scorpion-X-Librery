local function eseguiHit(targetPart)
    local srv = ReplicatedStorage:FindFirstChild("Aero") and ReplicatedStorage.Aero.AeroRemoteServices:FindFirstChild("GameService")
    if srv and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local pos = targetPart.Position + (targetPart.CFrame.RightVector * HITBOX_OFFSET_DIST)
        player.Character.HumanoidRootPart.CFrame = CFrame.new(pos, targetPart.Position)
        pcall(function()
            srv.WeaponAttackStart:FireServer()
            srv.MeleeHit:FireServer(targetPart)
            srv.WeaponAnimComplete:FireServer()
        end)
    end
end

