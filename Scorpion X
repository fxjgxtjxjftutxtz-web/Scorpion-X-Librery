local function calcolaPowerScoreSpada(item)
    if not wpnInvController then return 0 end
    local wpnSharedMod = wpnInvController.Shared.Weapons
    local config = wpnSharedMod.Data[item.id]
    if not config then return 0 end
    local dpsBase = (wpnSharedMod:GetWeaponDamage(item) or 0) * (config.APS or 1)
    local dpsConCritico = dpsBase * (1 + (config.Crit or 0))

    if modalitaSelezionata == "FARMING" then
        local wpnXpBoost = (wpnSharedMod.GetWeaponXp and wpnSharedMod:GetWeaponXp(item)) or (config.XpMultiplier or config.XpBoost or 0)
        return (wpnXpBoost > 0) and ((wpnXpBoost * 10000000) + dpsConCritico) or dpsConCritico
    end
    return dpsConCritico
end

local function calcolaPowerScoreSkin(item)
    if not skinInvController then return 0 end
    local skinSharedMod = skinInvController.Shared.Skins
    if modalitaSelezionata == "FARMING" then
        return (skinSharedMod:GetSkinXp(item) or 0) * 10000000
    end
    return (skinSharedMod:GetSkinHealth(item) or 0) + ((skinSharedMod:GetSkinRegen(item) or 0) * 150)
end

local function getClosestAvailableNode(character)
    if not resourceFolder or not character:FindFirstChild("HumanoidRootPart") then return nil, 0 end
    local myPos = character.HumanoidRootPart.Position
    local closestNode, shortestDistance = nil, math.huge
    
    local adesso = os.time()
    for n, scadenza in pairs(nodiBlacklist) do
        if adesso > scadenza then nodiBlacklist[n] = nil end
    end

    for _, node in ipairs(resourceFolder:GetChildren()) do
        if node.Name == TARGET_NAME and node:IsA("BasePart") and node:FindFirstChild("Prefab") and not nodiBlacklist[node] then
            local dist = (Vector3.new(myPos.X, 0, myPos.Z) - Vector3.new(node.Position.X, 0, node.Position.Z)).Magnitude
            if dist < shortestDistance then shortestDistance = dist; closestNode = node end
        end
    end
    return closestNode, shortestDistance
end

local function findCurrentBossTarget()
    if not npcFolder or not npcFolder:FindFirstChild("Boss") then return nil end
    for _, b in ipairs(npcFolder.Boss:GetChildren()) do
        if b:IsA("Model") then return b:FindFirstChild("LowerTorso") or b:FindFirstChild("HumanoidRootPart") end
    end
end

local function findDemonKingTarget()
    if not npcFolder or not npcFolder:FindFirstChild("DemonKing") then return nil end
    local dk = npcFolder.DemonKing:FindFirstChild("DemonKing")
    return dk and (dk:FindFirstChild("LowerTorso") or dk:FindFirstChild("HumanoidRootPart"))
end

local function getSortedPlayersByDistance()
    local list = {}
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return list end
    local myPos = player.Character.HumanoidRootPart.Position
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildOfClass("Humanoid") and p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
            table.insert(list, {playerObj = p, distance = (myPos - p.Character.HumanoidRootPart.Position).Magnitude})
        end
    end
    table.sort(list, function(a,b) return a.distance < b.distance end)
    return list
end

