local Library = {}

function Library:Inizializza(titoloHub)
    local Players = game:GetService("Players")
    local CoreGui = game:GetService("CoreGui")
    local player = Players.LocalPlayer
    local playerGui = player:WaitForChild("PlayerGui", 10) or player.PlayerGui

    -- Pulizia istanze attive precedenti
    local oldGui = playerGui:FindFirstChild("AeroAutoFarmMenu") or CoreGui:FindFirstChild("AeroAutoFarmMenu")
    if oldGui then oldGui:Destroy() end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "AeroAutoFarmMenu"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.DisplayOrder = 100

    local successo = pcall(function() ScreenGui.Parent = CoreGui end)
    if not successo then ScreenGui.Parent = playerGui end

    -- Finestra Principale
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(0.4, 0, 0.6, 0)
    MainFrame.Position = UDim2.new(0.3, 0, 0.2, 0)
    MainFrame.BackgroundColor3 = Color3.fromRGB(12, 12, 14)
    MainFrame.Visible = false
    MainFrame.Active = true
    MainFrame.Draggable = true
    MainFrame.Parent = ScreenGui

    local UIAspectRatio = Instance.new("UIAspectRatioConstraint")
    UIAspectRatio.AspectRatio = 1.4
    UIAspectRatio.AspectType = Enum.AspectType.ScaleWithParentSize
    UIAspectRatio.Parent = MainFrame

    local UICornerFrame = Instance.new("UICorner")
    UICornerFrame.CornerRadius = UDim.new(0, 12)
    UICornerFrame.Parent = MainFrame

    -- Bottone di attivazione Globale
    local ToggleMenuBtn = Instance.new("TextButton")
    ToggleMenuBtn.Name = "ToggleMenuBtn"
    ToggleMenuBtn.Size = UDim2.new(0, 180, 0, 45)
    ToggleMenuBtn.Position = UDim2.new(0, 20, 0.45, 0)
    ToggleMenuBtn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    ToggleMenuBtn.TextColor3 = Color3.fromRGB(240, 240, 240)
    ToggleMenuBtn.Font = Enum.Font.GothamBold
    ToggleMenuBtn.TextSize = 12
    ToggleMenuBtn.Text = "APRI " .. titoloHub:upper()
    ToggleMenuBtn.Parent = ScreenGui

    local UICornerBtn = Instance.new("UICorner")
    UICornerBtn.CornerRadius = UDim.new(0, 8)
    UICornerBtn.Parent = ToggleMenuBtn

    ToggleMenuBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = not MainFrame.Visible
        ToggleMenuBtn.Text = MainFrame.Visible and "CHIUDI HUB" or "APRI " .. titoloHub:upper()
    end)

    -- Layout Principale Interno (Sidebar + Contenuto)
    local SideBar = Instance.new("Frame")
    SideBar.Size = UDim2.new(0.28, 0, 0.85, 0)
    SideBar.Position = UDim2.new(0, 0, 0.15, 0)
    SideBar.BackgroundColor3 = Color3.fromRGB(8, 8, 10)
    SideBar.Parent = MainFrame

    local SideBarList = Instance.new("UIListLayout")
    SideBarList.Padding = UDim.new(0.02, 0)
    SideBarList.HorizontalAlignment = Enum.HorizontalAlignment.Center
    SideBarList.SortOrder = Enum.SortOrder.LayoutOrder
    SideBarList.Parent = SideBar

    local ContentContainer = Instance.new("Frame")
    ContentContainer.Size = UDim2.new(0.70, 0, 0.82, 0)
    ContentContainer.Position = UDim2.new(0.29, 0, 0.16, 0)
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Parent = MainFrame

    local EngineUI = { tabs = {}, tabButtons = {} }

    -- Generatore di Tab Dinamiche
    function EngineUI:CreaTab(name, order)
        local contentFrame = Instance.new("ScrollingFrame")
        contentFrame.Size = UDim2.new(1, 0, 1, 0)
        contentFrame.BackgroundTransparency = 1
        contentFrame.CanvasSize = UDim2.new(0, 0, 1.4, 0)
        contentFrame.ScrollBarThickness = 3
        contentFrame.Visible = false
        contentFrame.Parent = ContentContainer

        local listLayout = Instance.new("UIListLayout")
        listLayout.Padding = UDim.new(0.03, 0)
        listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        listLayout.Parent = contentFrame

        self.tabs[name] = contentFrame

        local tabBtn = Instance.new("TextButton")
        tabBtn.Size = UDim2.new(0.9, 0, 0.15, 0)
        tabBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
        tabBtn.TextColor3 = Color3.fromRGB(160, 160, 160)
        tabBtn.Font = Enum.Font.GothamSemibold
        tabBtn.TextSize = 10
        tabBtn.Text = name:upper()
        tabBtn.LayoutOrder = order
        tabBtn.Parent = SideBar

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 6)
        btnCorner.Parent = tabBtn

        tabBtn.MouseButton1Click:Connect(function()
            for tName, frame in pairs(self.tabs) do frame.Visible = (tName == name) end
            for bName, btn in pairs(self.tabButtons) do
                if bName == name then
                    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
                    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                else
                    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
                    btn.TextColor3 = Color3.fromRGB(160, 160, 160)
                end
            end
        end)

        self.tabButtons[name] = tabBtn
        return contentFrame
    end

    -- Generatore di Toggle standard
    function EngineUI:AggiungiToggle(parentTab, titleText, descText, defaultState, callback)
        local container = Instance.new("Frame")
        container.Size = UDim2.new(0.95, 0, 0, 50)
        container.AutomaticSize = Enum.AutomaticSize.Y
        container.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
        container.Parent = parentTab

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 6)
        corner.Parent = container

        local titleLabel = Instance.new("TextLabel")
        titleLabel.Size = UDim2.new(0.70, 0, 0, 20)
        titleLabel.Position = UDim2.new(0.03, 0, 0, 4)
        titleLabel.BackgroundTransparency = 1
        titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        titleLabel.Font = Enum.Font.GothamBold
        titleLabel.TextSize = 12
        titleLabel.TextXAlignment = Enum.TextXAlignment.Left
        titleLabel.Text = titleText
        titleLabel.Parent = container

        local descLabel = Instance.new("TextLabel")
        descLabel.Size = UDim2.new(0.70, 0, 0, 24)
        descLabel.Position = UDim2.new(0.03, 0, 0, 22)
        descLabel.BackgroundTransparency = 1
        descLabel.TextColor3 = Color3.fromRGB(160, 160, 160)
        descLabel.Font = Enum.Font.Gotham
        descLabel.TextSize = 10
        descLabel.TextXAlignment = Enum.TextXAlignment.Left
        descLabel.TextWrapped = true
        descLabel.Text = descText
        descLabel.Parent = container

        local toggleBtn = Instance.new("TextButton")
        toggleBtn.Size = UDim2.new(0.20, 0, 0, 25)
        toggleBtn.Position = UDim2.new(0.75, 0, 0.25, 0)
        toggleBtn.Font = Enum.Font.GothamBold
        toggleBtn.TextSize = 10
        toggleBtn.Parent = container

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 4)
        btnCorner.Parent = toggleBtn

        local state = defaultState
        local function updateVisual()
            if state then
                toggleBtn.Text = "ON"
                toggleBtn.BackgroundColor3 = Color3.fromRGB(46, 117, 89)
            else
                toggleBtn.Text = "OFF"
                toggleBtn.BackgroundColor3 = Color3.fromRGB(117, 46, 46)
            end
        end

        updateVisual()
        toggleBtn.MouseButton1Click:Connect(function()
            state = not state
            updateVisual()
            callback(state)
        end)

        return container, toggleBtn
    end

    -- Generatore di Dropdown (Selettori Avanzati)
    function EngineUI:AggiungiDropdown(parentTab, options, defaultText, prefixText, callback)
        local dropContainer = Instance.new("Frame")
        dropContainer.Size = UDim2.new(0.95, 0, 0, 35)
        dropContainer.BackgroundTransparency = 1
        dropContainer.Parent = parentTab

        local dropBtn = Instance.new("TextButton")
        dropBtn.Size = UDim2.new(1, 0, 1, 0)
        dropBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
        dropBtn.TextColor3 = Color3.fromRGB(235, 190, 80)
        dropBtn.Font = Enum.Font.GothamBold
        dropBtn.TextSize = 11
        dropBtn.Text = defaultText
        dropBtn.Parent = dropContainer

        local dropCorner = Instance.new("UICorner")
        dropCorner.CornerRadius = UDim.new(0, 6)
        dropCorner.Parent = dropBtn

        local dropListFrame = Instance.new("Frame")
        dropListFrame.Size = UDim2.new(1, 0, 0, #options * 25)
        dropListFrame.Position = UDim2.new(0, 0, 1, 2)
        dropListFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
        dropListFrame.Visible = false
        dropListFrame.ZIndex = 50
        dropListFrame.Parent = dropContainer

        local dropLayout = Instance.new("UIListLayout")
        dropLayout.Parent = dropListFrame

        for _, item in ipairs(options) do
            local opt = Instance.new("TextButton")
            opt.Size = UDim2.new(1, 0, 0, 25)
            opt.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
            opt.TextColor3 = Color3.fromRGB(240, 240, 240)
            opt.Font = Enum.Font.GothamSemibold
            opt.TextSize = 10
            opt.Text = item.Text
            opt.ZIndex = 51
            opt.Parent = dropListFrame

            opt.Activated:Connect(function()
                dropBtn.Text = prefixText .. item.Text
                dropListFrame.Visible = false
                callback(item.Value)
            end)
        end
        
        dropBtn.Activated:Connect(function() dropListFrame.Visible = not dropListFrame.Visible end)
    end

    return EngineUI
end

return Library
