        local toggleBg = Instance.new("Frame"); toggleBg.Size = UDim2.new(0, 38, 0, 20); toggleBg.Position = UDim2.new(1, -50, 0.5, -10); toggleBg.BackgroundColor3 = Color3.fromRGB(30, 30, 35); toggleBg.Parent = container
        local toggleBgCorner = Instance.new("UICorner"); toggleBgCorner.CornerRadius = UDim.new(1, 0); toggleBgCorner.Parent = toggleBg
        local toggleBall = Instance.new("Frame"); toggleBall.Size = UDim2.new(0, 14, 0, 14); toggleBall.Position = UDim2.new(0, 3, 0, 3); toggleBall.BackgroundColor3 = Color3.fromRGB(150, 150, 155); toggleBall.Parent = toggleBg
        local toggleBallCorner = Instance.new("UICorner"); toggleBallCorner.CornerRadius = UDim.new(1, 0); toggleBallCorner.Parent = toggleBall
        local clickBtn = Instance.new("TextButton"); clickBtn.Size = UDim2.new(1, 0, 1, 0); clickBtn.BackgroundTransparency = 1; clickBtn.Text = ""; clickBtn.Parent = container

        local state = defaultState
        local function updateVisual(smooth)
            local targetBg = state and VerdeTemaHover or Color3.fromRGB(30, 30, 35)
            local targetPos = state and UDim2.new(0, 21, 0, 3) or UDim2.new(0, 3, 0, 3)
            local targetBallColor = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(150, 150, 155)
            if smooth then ApplicaTween(toggleBg, 0.2, {BackgroundColor3 = targetBg}); ApplicaTween(toggleBall, 0.18, {Position = targetPos, BackgroundColor3 = targetBallColor})
            else toggleBg.BackgroundColor3 = targetBg; toggleBall.Position = targetPos; toggleBall.BackgroundColor3 = targetBallColor end
        end
        updateVisual(false)
        clickBtn.MouseButton1Click:Connect(function() state = not state; updateVisual(true); callback(state) end)
        return container
    end

    function InterfacciaEngine:AggiungiDropdown(parentTab, options, defaultText, callback)
        local currentSelectedText = defaultText
