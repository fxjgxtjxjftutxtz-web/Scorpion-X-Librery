    else
        ToggleMenuBtn.Text = "REDZ"; ToggleMenuBtn.TextColor3 = ColoreAccento; ToggleMenuBtn.Font = Enum.Font.GothamBold; ToggleMenuBtn.TextSize = 10
    end
    ToggleMenuBtn.MouseButton1Click:Connect(function() MainFrame.Visible = not MainFrame.Visible end)

    local menuBind = tastoChiusuraDefault or Enum.KeyCode.RightControl
    UserInputService.InputBegan:Connect(function(input, processed) if not processed and input.KeyCode == menuBind then MainFrame.Visible = not MainFrame.Visible end end)

    local SideBar = Instance.new("ScrollingFrame")
    SideBar.Name = "SideBar"; SideBar.Size = UDim2.new(0, 160, 1, -48); SideBar.Position = UDim2.new(0, 8, 0, 42); SideBar.BackgroundTransparency = 1; SideBar.ScrollBarThickness = 0; SideBar.Parent = MainFrame
    local SideBarList = Instance.new("UIListLayout"); SideBarList.Padding = UDim.new(0, 5); SideBarList.SortOrder = Enum.SortOrder.LayoutOrder; SideBarList.Parent = SideBar

    local ContentContainer = Instance.new("Frame")
    ContentContainer.Name = "ContentContainer"; ContentContainer.Size = UDim2.new(1, -182, 1, -48); ContentContainer.Position = UDim2.new(0, 174, 0, 42); ContentContainer.BackgroundTransparency = 1; ContentContainer.Parent = MainFrame

    local InterfacciaEngine = { tabs = {}, tabButtons = {}, primaTab = nil, activeDropdownFrame = nil, activeDropdownContainer = nil }

    function InterfacciaEngine:CreaTab(name, idIcona)
        local contentFrame = Instance.new("ScrollingFrame")
        contentFrame.Name = name .. "Tab"; contentFrame.Size = UDim2.new(1, 0, 1, 0); contentFrame.BackgroundTransparency = 1; contentFrame.CanvasSize = UDim2.new(0, 0, 0, 0); contentFrame.ScrollBarThickness = 3; contentFrame.ScrollBarImageColor3 = Color3.fromRGB(45, 45, 50); contentFrame.Visible = false; contentFrame.Parent = ContentContainer
        local listLayout = Instance.new("UIListLayout"); listLayout.Padding = UDim.new(0, 6); listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center; listLayout.SortOrder = Enum.SortOrder.LayoutOrder; listLayout.Parent = contentFrame
        listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() contentFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 15) end)
        InterfacciaEngine.tabs[name] = contentFrame

        local tabBtn = Instance.new("TextButton")
        tabBtn.Name = name .. "Btn"; tabBtn.Size = UDim2.new(1, -5, 0, 36); tabBtn.BackgroundColor3 = Color3.fromRGB(24, 24, 26); tabBtn.Text = "" ; tabBtn.Parent = SideBar
        local btnCorner = Instance.new("UICorner"); btnCorner.CornerRadius = UDim.new(0, 6); btnCorner.Parent = tabBtn
        local btnStroke = Instance.new("UIStroke"); btnStroke.Thickness = 1; btnStroke.Color = Color3.fromRGB(32, 32, 35); btnStroke.Parent = tabBtn

        local indicator = Instance.new("Frame")
        indicator.Size = UDim2.new(0, 3, 0, 16); indicator.Position = UDim2.new(0, 0, 0.5, -8); indicator.BackgroundColor3 = ColoreAccento; indicator.BackgroundTransparency = 1; indicator.Parent = tabBtn
        local indCorner = Instance.new("UICorner"); indCorner.Parent = indicator

        local offsetTesto = 12
        if idIcona and idIcona ~= "" then
            local tIcon = Instance.new("ImageLabel")
            tIcon.Size = UDim2.new(0, 16, 0, 16); tIcon.Position = UDim2.new(0, 10, 0.5, -8); tIcon.BackgroundTransparency = 1; tIcon.Image = "rbxassetid://" .. tostring(idIcona):match("%d+")
            tIcon.ImageColor3 = ColoreTestoSecondario; tIcon.Parent = tabBtn
            offsetTesto = 32
        end

        local tLabel = Instance.new("TextLabel")
        tLabel.Size = UDim2.new(1, -offsetTesto, 1, 0); tLabel.Position = UDim2.new(0, offsetTesto, 0, 0); tLabel.BackgroundTransparency = 1; tLabel.TextColor3 = ColoreTestoSecondario; tLabel.Font = Enum.Font.GothamMedium; tLabel.TextSize = 12; tLabel.TextXAlignment = Enum.TextXAlignment.Left; tLabel.Text = name; tLabel.Parent = tabBtn

        if not InterfacciaEngine.primaTab then 
            InterfacciaEngine.primaTab = name; contentFrame.Visible = true; tLabel.TextColor3 = ColoreTestoPrincipale; tabBtn.BackgroundColor3 = ColoreElemento; indicator.BackgroundTransparency = 0
        end

        tabBtn.MouseButton1Click:Connect(function()
            for tName, frame in pairs(InterfacciaEngine.tabs) do frame.Visible = (tName == name) end
            for bName, bObj in pairs(InterfacciaEngine.tabButtons) do
                if bName == name then
                    ApplicaTween(bObj, 0.15, {BackgroundColor3 = ColoreElemento})
                    ApplicaTween(bObj.TextLabel, 0.15, {TextColor3 = ColoreTestoPrincipale})
                    ApplicaTween(bObj.Frame, 0.15, {BackgroundTransparency = 0})
                else
                    ApplicaTween(bObj, 0.15, {BackgroundColor3 = Color3.fromRGB(24, 24, 26)})
                    ApplicaTween(bObj.TextLabel, 0.15, {TextColor3 = ColoreTestoSecondario})
                    ApplicaTween(bObj.Frame, 0.15, {BackgroundTransparency = 1})
                end
            end
        end)
        InterfacciaEngine.tabButtons[name] = tabBtn
        return contentFrame
    end

    function InterfacciaEngine:AggiungiParagraph(parentTab, titleText)
        local pLabel = Instance.new("TextLabel")
        pLabel.Size = UDim2.new(0.96, 0, 0, 26); pLabel.BackgroundTransparency = 1; pLabel.TextColor3 = ColoreTestoPrincipale; pLabel.Font = Enum.Font.GothamBold; pLabel.TextSize = 13; pLabel.TextXAlignment = Enum.TextXAlignment.Left; pLabel.Text = titleText; pLabel.Parent = parentTab
        return pLabel
    end

    function InterfacciaEngine:AggiungiToggle(parentTab, titleText, descText, defaultState, callback)
        local container = Instance.new("Frame"); container.Size = UDim2.new(0.96, 0, 0, 40); container.BackgroundColor3 = Color3.fromRGB(24, 24, 26); container.Parent = parentTab
        local corner = Instance.new("UICorner"); corner.CornerRadius = UDim.new(0, 6); corner.Parent = container
        
        local titleLabel = Instance.new("TextLabel"); titleLabel.Size = UDim2.new(0.7, 0, 0, 18); titleLabel.Position = UDim2.new(0, 12, 0, 3); titleLabel.BackgroundTransparency = 1; titleLabel.TextColor3 = ColoreTestoPrincipale; titleLabel.Font = Enum.Font.GothamMedium; titleLabel.TextSize = 12; titleLabel.TextXAlignment = Enum.TextXAlignment.Left; titleLabel.Text = titleText; titleLabel.Parent = container
        local descLabel = Instance.new("TextLabel"); descLabel.Size = UDim2.new(0.7, 0, 0, 14); descLabel.Position = UDim2.new(0, 12, 0, 20); descLabel.BackgroundTransparency = 1; descLabel.TextColor3 = ColoreTestoSecondario; descLabel.Font = Enum.Font.Gotham; descLabel.TextSize = 10; descLabel.TextXAlignment = Enum.TextXAlignment.Left; descLabel.Text = descText; descLabel.Parent = container
        
        local toggleBg = Instance.new("Frame"); toggleBg.Size = UDim2.new(0, 34, 0, 18); toggleBg.Position = UDim2.new(1, -44, 0.5, -9); toggleBg.BackgroundColor3 = Color3.fromRGB(40, 40, 44); toggleBg.Parent = container
        local toggleBgCorner = Instance.new("UICorner"); toggleBgCorner.CornerRadius = UDim.new(1, 0); toggleBgCorner.Parent = toggleBg
        local toggleBall = Instance.new("Frame"); toggleBall.Size = UDim2.new(0, 12, 0, 12); toggleBall.Position = UDim2.new(0, 3, 0, 3); toggleBall.BackgroundColor3 = Color3.fromRGB(180, 180, 185); toggleBall.Parent = toggleBg
        local toggleBallCorner = Instance.new("UICorner"); toggleBallCorner.CornerRadius = UDim.new(1, 0); toggleBallCorner.Parent = toggleBall
        
        local clickBtn = Instance.new("TextButton"); clickBtn.Size = UDim2.new(1, 0, 1, 0); clickBtn.BackgroundTransparency = 1; clickBtn.Text = ""; clickBtn.Parent = container

        local state = defaultState
        local function updateVisual(smooth)
            local targetBg = state and ColoreAccento or Color3.fromRGB(40, 40, 44)
            local targetPos = state and UDim2.new(0, 19, 0, 3) or UDim2.new(0, 3, 0, 3)
            local targetBallColor = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 185)
            if smooth then ApplicaTween(toggleBg, 0.15, {BackgroundColor3 = targetBg}); ApplicaTween(toggleBall, 0.15, {Position = targetPos, BackgroundColor3 = targetBallColor})
            else toggleBg.BackgroundColor3 = targetBg; toggleBall.Position = targetPos; toggleBall.BackgroundColor3 = targetBallColor end
        end
        updateVisual(false)
        clickBtn.MouseButton1Click:Connect(function() state = not state; updateVisual(true); callback(state) end)
        return container
    end

    function InterfacciaEngine:AggiungiBottone(parentTab, buttonText, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0.96, 0, 0, 34); btn.BackgroundColor3 = Color3.fromRGB(24, 24, 26); btn.TextColor3 = ColoreTestoPrincipale; btn.Font = Enum.Font.GothamMedium; btn.TextSize = 12; btn.Text = buttonText; btn.Parent = parentTab
        local bCorner = Instance.new("UICorner"); bCorner.CornerRadius = UDim.new(0, 6); bCorner.Parent = btn
        local bStroke = Instance.new("UIStroke"); bStroke.Thickness = 1; bStroke.Color = Color3.fromRGB(34, 34, 38); bStroke.Parent = btn

        btn.MouseEnter:Connect(function() ApplicaTween(btn, 0.1, {BackgroundColor3 = ColoreElemento}) end)
        btn.MouseLeave:Connect(function() ApplicaTween(btn, 0.1, {BackgroundColor3 = Color3.fromRGB(24, 24, 26)}) end)
        btn.MouseButton1Click:Connect(callback)
        return btn
    end

    function InterfacciaEngine:AggiungiDropdown(parentTab, options, defaultText, callback)
        local currentText = defaultText
        local dropContainer = Instance.new("Frame"); dropContainer.Size = UDim2.new(0.96, 0, 0, 34); dropContainer.BackgroundTransparency = 1; dropContainer.ClipsDescendants = true; dropContainer.Parent = parentTab
        
        local dropBtn = Instance.new("TextButton"); dropBtn.Size = UDim2.new(1, 0, 0, 34); dropBtn.BackgroundColor3 = Color3.fromRGB(24, 24, 26); dropBtn.TextColor3 = ColoreTestoPrincipale; dropBtn.Font = Enum.Font.GothamMedium; dropBtn.TextSize = 12; dropBtn.Text = "  " .. currentText .. "    ▼"; dropBtn.TextXAlignment = Enum.TextXAlignment.Left; dropBtn.Parent = dropContainer
        local dCorner = Instance.new("UICorner"); dCorner.CornerRadius = UDim.new(0, 6); dCorner.Parent = dropBtn
        
        local dropListFrame = Instance.new("ScrollingFrame"); dropListFrame.Size = UDim2.new(1, 0, 0, 0); dropListFrame.Position = UDim2.new(0, 0, 0, 36); dropListFrame.BackgroundColor3 = Color3.fromRGB(18, 18, 20); dropListFrame.ScrollBarThickness = 2; dropListFrame.Visible = false; dropListFrame.Parent = dropContainer
        local dlList = Instance.new("UIListLayout"); dlList.SortOrder = Enum.SortOrder.LayoutOrder; dlList.Parent = dropListFrame

        for i, val in ipairs(options) do
            local optText = tostring(val.Text or val)
            local optVal = val.Value or val
            local opt = Instance.new("TextButton"); opt.Size = UDim2.new(1, 0, 0, 28); opt.BackgroundColor3 = Color3.fromRGB(18, 18, 20); opt.TextColor3 = ColoreTestoSecondario; opt.Font = Enum.Font.Gotham; opt.TextSize = 12; opt.Text = "    " .. optText; opt.TextXAlignment = Enum.TextXAlignment.Left; opt.LayoutOrder = i; opt.Parent = dropListFrame
            
            opt.MouseEnter:Connect(function() ApplicaTween(opt, 0.1, {BackgroundColor3 = Color3.fromRGB(26, 26, 30), TextColor3 = ColoreTestoPrincipale}) end)
            opt.MouseLeave:Connect(function() ApplicaTween(opt, 0.1, {BackgroundColor3 = Color3.fromRGB(18, 18, 20), TextColor3 = ColoreTestoSecondario}) end)
            opt.MouseButton1Click:Connect(function()
                currentText = optText; dropBtn.Text = "  " .. currentText .. "    ▼"
                dropListFrame.Visible = false; dropContainer.Size = UDim2.new(0.96, 0, 0, 34)
                callback(optVal)
            end)
        end

        dropBtn.MouseButton1Click:Connect(function()
            if dropListFrame.Visible then
                dropListFrame.Visible = false; dropContainer.Size = UDim2.new(0.96, 0, 0, 34)
            else
                dropListFrame.Visible = true
                local altezzaCalculata = math.min(#options * 28, 115)
                dropListFrame.Size = UDim2.new(1, 0, 0, altezzaCalculata)
                dropContainer.Size = UDim2.new(0.96, 0, 0, 36 + altezzaCalculata)
            end
        end)
    end

    return InterfacciaEngine
end

return Library
