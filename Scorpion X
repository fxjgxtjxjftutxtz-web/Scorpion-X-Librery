    function InterfacciaEngine:AggiungiKeybind(parentTab, titleText, defaultKey, callback)
        local container = Instance.new("Frame")
        container.Size = UDim2.new(0.95, 0, 0, 42)
        container.BackgroundColor3 = Color3.fromRGB(15, 15, 17)
        container.Parent = parentTab

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 6)
        corner.Parent = container

        local titleLabel = Instance.new("TextLabel")
        titleLabel.Size = UDim2.new(0.6, 0, 1, 0)
        titleLabel.Position = UDim2.new(0, 12, 0, 0)
        titleLabel.BackgroundTransparency = 1
        titleLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
        titleLabel.Font = Enum.Font.GothamSemibold
        titleLabel.TextSize = 12
        titleLabel.TextXAlignment = Enum.TextXAlignment.Left
        titleLabel.Text = titleText
        titleLabel.Parent = container

        local bindBtn = Instance.new("TextButton")
        bindBtn.Size = UDim2.new(0, 85, 0, 24)
        bindBtn.Position = UDim2.new(1, -97, 0.5, -12)
        bindBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
        bindBtn.TextColor3 = VerdeTema
        bindBtn.Font = Enum.Font.GothamBold
        bindBtn.TextSize = 10
        bindBtn.Text = defaultKey.Name:upper()
        bindBtn.Parent = container

        local bCorner = Instance.new("UICorner")
        bCorner.CornerRadius = UDim.new(0, 4)
        bCorner.Parent = bindBtn
        
        local bStroke = Instance.new("UIStroke")
        bStroke.Thickness = 1
        bStroke.Color = Color3.fromRGB(35, 35, 40)
        bStroke.Parent = bindBtn

        local currentKey = defaultKey
        local listening = false

        bindBtn.MouseButton1Click:Connect(function()
            listening = true
            bindBtn.Text = "..."
            ApplicaTween(bStroke, 0.15, {Color = Color3.fromRGB(200, 150, 0)})
            bindBtn.TextColor3 = Color3.fromRGB(200, 150, 0)
        end)

        UserInputService.InputBegan:Connect(function(input, processed)
            if processed then return end
            if listening and input.UserInputType == Enum.UserInputType.Keyboard then
                listening = false
                currentKey = input.KeyCode
                bindBtn.Text = currentKey.Name:upper()
                ApplicaTween(bStroke, 0.15, {Color = Color3.fromRGB(35, 35, 40)})
                bindBtn.TextColor3 = VerdeTema
                callback(currentKey, false)
            elseif not listening and input.KeyCode == currentKey then
                callback(currentKey, true)
            end
        end)

        return container
    end

    return InterfacciaEngine
end

